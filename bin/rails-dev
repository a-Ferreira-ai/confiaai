#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
BACKEND="$ROOT/backend"
PORT="${RAILS_PORT:-3000}"
PIDFILE="$BACKEND/tmp/pids/server.pid"

cd "$BACKEND"

if [ -f "$PIDFILE" ]; then
  pid="$(cat "$PIDFILE")"
  if kill -0 "$pid" 2>/dev/null; then
    echo "Rails already running (pid ${pid}) on port ${PORT} — reusing existing instance"
    exec sleep infinity
  fi
  echo "Removing stale Rails pid file (pid ${pid} not running)"
  rm -f "$PIDFILE"
fi

if curl -sf "http://127.0.0.1:${PORT}/up" >/dev/null 2>&1; then
  echo "Something already responding on port ${PORT} — reusing existing instance"
  exec sleep infinity
fi

exec bin/rails server -p "$PORT"
